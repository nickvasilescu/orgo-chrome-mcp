{
  "name": "orgo-chrome-mcp",
  "version": "0.2.0",
  "description": "MCP server for DOM-aware Chrome browser automation inside Orgo VMs",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "orgo-chrome-mcp": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build && mkdir -p dist/bridge && cp src/bridge/orgo-chrome-bridge.js dist/bridge/"
  },
  "keywords": ["mcp", "orgo", "chrome", "browser", "automation", "cdp", "devtools"],
  "author": "Orgo <spencer@orgo.ai>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nickvasilescu/orgo-chrome-mcp"
  },
  "homepage": "https://github.com/nickvasilescu/orgo-chrome-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.25.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
